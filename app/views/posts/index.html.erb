<div class="row">
  <% for post in @posts %>
    <div class="col-3">
      <h4>
        <% post_user = User.find_by({ "id" => post["user_id"] }) %>
        <%= post_user ? post_user["first_name"] : "anonymous" %>
      </h4>
      <img src="<%= post["image"] %>" class="img-fluid w-full">
      <p><%= post["body"] %></p>
    </div>
  <% end %>
</div>